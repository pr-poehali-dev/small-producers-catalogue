{
  "tests": [
    {
      "name": "Register manufacturer",
      "method": "POST",
      "path": "/register",
      "body": {"email": "test_mfr_new@example.com", "password": "test123", "role": "manufacturer"},
      "expectedStatus": 200,
      "expectedBody": {"role": "manufacturer"},
      "bodyMatcher": "partial"
    },
    {
      "name": "Login with unconfirmed email",
      "method": "POST",
      "path": "/login",
      "body": {"email": "test_mfr_new@example.com", "password": "test123"},
      "expectedStatus": 403,
      "expectedBody": {"error": "Email не подтверждён. Проверьте почту."},
      "bodyMatcher": "partial"
    }
  ]
}
